---
const contactValue = "msg@no-tone.com";
---

<footer class="bottombar">
  <nav class="bottombar__nav" aria-label="Social">
    <a
      class="bottombar__link"
      href="https://github.com/n0-tone"
      target="_blank"
      rel="nofollow noreferrer noopener">github</a
    >
    <span class="bottombar__sep" aria-hidden="true">/</span>
    <button
      class="bottombar__link"
      type="button"
      data-copy-contact
      data-copy-value={contactValue}>contact</button
    >
  </nav>
</footer>

<script type="module" src="/scripts/footer.js"></script>
