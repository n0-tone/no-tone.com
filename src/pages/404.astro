---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="no-tone | 404"
      description="The page you were looking for does not exist. Browse projects, TLDR notes, or the usr directory instead."
    />
  </head>
  <body>
    <Header />
    <main class="note note--error">
      <p class="note__date">404</p>
      <h1 class="page__title page__title--error">404</h1>
    </main>
    <Footer />
  </body>
</html>
